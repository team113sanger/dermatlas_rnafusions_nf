params {
    fastq_path = "${PROJECT_DIR}/fastq/**_{1,2}.fastq.gz"
    sample_metadata = "${METADATA_DIR}/samples_noduplicates.tsv"
    outdir = "${ANALYSIS_DIR}/star-fusion"
    ctat_lib = "/lustre/scratch125/casm/teams/team113/resources/references/dermatlas/star_fusion/GRCh38_gencode_v37_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir"

    // Define subcohorts - each key is the subcohort name (used as study_id in outputs)
    // Each value must contain a sample_list path pointing to a file with sample IDs (one per line)
    subcohorts = [
        "${STUDY}_one_per_patient": [
            sample_list: "${PROJECT_DIR}/metadata/${STUDY}_one_samp_ppat_sampnames.tsv"
        ],
        "${STUDY}_all_samples": [
            sample_list: "${PROJECT_DIR}/metadata/${STUDY}_all_sampnames.tsv"
        ]
    ]
}